#!/usr/bin/env php
<?php

// 1. Requerimos tu configuración nativa primero.
require_once __DIR__ . '/App/config/config.php';

// 2. AUTOLOADER CRÍTICO: Mapea correctamente la raíz del proyecto y namespaces
spl_autoload_register(function ($class) {
    $file = __DIR__ . '/' . str_replace('\\', '/', $class) . '.php';
    if (file_exists($file)) {
        require_once $file;
    }
});

// 3. Definimos las constantes restantes basándose en tu estructura de carpetas
define('CONTROLLERS_PATH', RUTA_APP . '/Controllers/');
define('MODELS_PATH', RUTA_APP . '/Models/');
define('MIGRATIONS_PATH', __DIR__ . '/database/migrations/');
define('STUBS_PATH', __DIR__ . '/Core/Stubs/');
define('SEEDERS_PATH', __DIR__ . '/database/seeders/');

$command = $argv[1] ?? null;
$name = $argv[2] ?? null;

// Capturar todas las banderas separadas por espacios
$flags = array_slice($argv, 3);
$isResource = in_array('-r', $flags) || in_array('--resource', $flags);
$createModel = in_array('-m', $flags) || in_array('--model', $flags);
$createController = in_array('-c', $flags) || in_array('--controller', $flags);
$createMigration = in_array('-g', $flags) || in_array('--migration', $flags) || in_array('-m', $flags); // -m suele usarse para migración en modelos

if (!$command) {
    echo "\e[33mMini Laravel - CLI Craft (SIAE 2026)\e[0m\n";
    echo "Uso:\n";
    echo "  php craft make:controller {Nombre} [-r] [-m]\n";
    echo "  php craft make:model {Nombre} [-m] [-c] [-r]\n";
    echo "  php craft make:migration create_{nombre}_table [--create=tabla]\n";
    echo "  php craft make:seeder {Nombre}\n";
    echo "  php craft migrate\n";
    echo "  php craft migrate:rollback\n";
    echo "  php craft db:seed [{Nombre}] [--refresh]\n\n";
    echo "  php craft make:crud {nombre_tabla}\n";
    echo "Opciones y Banderas:\n";
    echo "  -m, --model       Genera un modelo acoplado (al crear controlador) o migración (al crear modelo).\n";
    echo "  -c, --controller  Genera un controlador básico acoplado al modelo.\n";
    echo "  -r, --resource    Genera un controlador estructurado tipo Recurso (CRUD).\n";
    echo "  --refresh         Vacía las tablas mediante TRUNCATE antes de ejecutar los seeders.\n";
    exit(0);
}

// ==========================================
// FUNCIONES AUXILIARES DE GENERACIÓN
// ==========================================
function generarMigración($name, $forcedTableName = null) {
    if (!is_dir(MIGRATIONS_PATH)) {
        mkdir(MIGRATIONS_PATH, 0755, true);
    }
    
    // 1. Si se pasó una tabla por la bandera --create, la usamos directamente.
    // De lo contrario, sanitizamos el nombre de la migración.
    if ($forcedTableName) {
        $pureName = strtolower($forcedTableName);
    } else {
        $pureName = str_replace(['create_', '_table'], '', strtolower($name));
        
        // 2. PLURALIZACIÓN INTELIGENTE NATIVA (Tu lógica existente)
        if (!str_ends_with($pureName, 's')) {
            $pureName .= 's';
        }
    }
    
    // 3. Estandarizar el nombre del archivo y de la tabla (ej: create_ofertas_educativas_table)
    $migrationName = 'create_' . str_replace(['create_', '_table'], '', strtolower($name)) . '_table';
    $tableName = $pureName;
    
    // 4. Convertir a CamelCase para la Clase (ej: CreateOfertasEducativasTable)
    $className = str_replace(' ', '', ucwords(str_replace('_', ' ', $migrationName)));

    $timestamp = date('Y_m_d_His');
    $filename = $timestamp . '_' . $migrationName . '.php';
    $targetFile = MIGRATIONS_PATH . $filename;

    if (!file_exists(STUBS_PATH . 'Migration.stub')) {
        echo "\e[31mError:\e[0m Falta plantilla Migration.stub\n";
        return;
    }

    $template = file_get_contents(STUBS_PATH . 'Migration.stub');
    $compiled = str_replace(['{{MigrationClass}}', '{{TableName}}'], [$className, $tableName], $template);
    
    file_put_contents($targetFile, $compiled);
    echo "\e[32mMigración creada con éxito:\e[0m database/migrations/{$filename} (Tabla: {$tableName})\n";
}

function generarControlador($name, $isResource, $descomentarCrud = false) {
    // 1. Asegurar el sufijo Controller e identificar rutas / subcarpetas
    if (!str_ends_with($name, 'Controller')) $name .= 'Controller';
    $name = trim(str_replace('\\', '/', $name), '/');
    $parts = explode('/', $name);
    
    $className = array_pop($parts); // "OfertasEducativasController"
    $subFolders = implode('/', $parts); // "Admin" o vacío

    // 2. Definir rutas físicas y namespaces dinámicos
    $targetDir = CONTROLLERS_PATH . ($subFolders ? $subFolders . '/' : '');
    $targetFile = $targetDir . $className . '.php';

    $namespaceBase = 'App\Controllers';
    $namespaceFinal = $subFolders 
        ? $namespaceBase . '\\' . str_replace('/', '\\', $subFolders) 
        : $namespaceBase;

    // 3. Validar existencia del archivo controlador
    if (file_exists($targetFile)) {
        echo "\e[33mEl controlador [{$name}] ya existe.\e[0m\n";
        return;
    }

    // 4. Cargar plantilla (Stub de recurso o básica)
    if ($isResource) {
        if (!file_exists(STUBS_PATH . 'Controller.stub')) {
            echo "\e[31mError:\e[0m Falta plantilla Controller.stub\n";
            return;
        }
        $template = file_get_contents(STUBS_PATH . 'Controller.stub');
    } else {
        $template = "<?php\n\nnamespace {{Namespace}};\n\nuse App\Controllers\Controller;\n\nclass {{ClassName}} extends Controller\n{\n    public function index()\n    {\n        //\n    }\n}\n";
    }

    // 5. Crear los directorios físicos si no existen
    if (!is_dir($targetDir)) {
        mkdir($targetDir, 0755, true);
    }

    // 6. Calcular variables de reemplazo basadas en el nombre limpio de la clase
    $baseName = str_replace('Controller', '', $className);
    $lowerName = strtolower($baseName);

    $compiled = str_replace(
        ['{{Namespace}}', '{{ClassName}}', '{{LowerName}}'], 
        [$namespaceFinal, $className, $lowerName], 
        $template
    );
    
    // 7. Tu lógica nativa: Activar líneas comentadas si viene de make:crud
    if ($descomentarCrud) {
        $compiled = preg_replace('/^\s*\/+\s*(\$this->model|\$data|return redirect|return \$this)/m', '$1', $compiled);
    }

    // 8. Escribir archivo final
    file_put_contents($targetFile, $compiled);
    echo "\e[32mControlador creado con éxito:\e[0m App/Controllers/{$name}.php\n";
}


function generarModelo($name) {
    // 1. Limpiar barras y separar el nombre de la clase de las subcarpetas
    $name = trim(str_replace('\\', '/', $name), '/');
    $parts = explode('/', $name);
    $className = array_pop($parts); // "OfertasEducativas"
    $subFolders = implode('/', $parts); // "Admin" (o vacío si no hay)

    // 2. Determinar la ruta final y el namespace dinámico
    $targetDir = MODELS_PATH . ($subFolders ? $subFolders . '/' : '');
    $targetFile = $targetDir . $className . '.php';

    $namespaceBase = 'App\Models';
    $namespaceFinal = $subFolders 
        ? $namespaceBase . '\\' . str_replace('/', '\\', $subFolders) 
        : $namespaceBase;

    // 3. Validar existencia del archivo
    if (file_exists($targetFile)) {
        echo "\e[33mEl modelo [{$name}] ya existe.\e[0m\n";
        return;
    }

    // 4. Validar que exista la plantilla stub
    if (!file_exists(STUBS_PATH . 'Model.stub')) {
        echo "\e[31mError:\e[0m Falta plantilla Model.stub\n";
        return;
    }

    // 5. Crear los directorios físicos si no existen
    if (!is_dir($targetDir)) {
        mkdir($targetDir, 0755, true);
    }

    // 6. Calcular el nombre de la tabla en snake_case (ej: "ofertas_educativas_table" -> "ofertas_educativas")
    $snakeName = strtolower(preg_replace('/(?<!^)[A-Z]/', '_$0', $className));
    $tableName = $snakeName . 's';

    // 7. Leer, reemplazar variables e inyectar el Namespace
    $template = file_get_contents(STUBS_PATH . 'Model.stub');
    
    $compiled = str_replace(
        ['{{Namespace}}', '{{ModelName}}', '{{TableName}}'], 
        [$namespaceFinal, $className, $tableName], 
        $template
    );

    // 8. Guardar archivo final
    file_put_contents($targetFile, $compiled);
    echo "\e[32mModelo creado con éxito:\e[0m App/Models/{$name}.php (Tabla: {$tableName})\n";
}


// ==========================================
// COMANDO: php craft make:migration
// ==========================================
if ($command === 'make:migration') {
    if (!$name) {
        echo "\e[31mError:\e[0m Debes especificar el nombre de la migración.\n";
        exit(1);
    }

    $tableName = null;

    // Analizar las banderas buscando --create=tabla
    foreach ($flags as $flag) {
        if (str_starts_with($flag, '--create=')) {
            $tableName = substr($flag, 9); // Extrae lo que esté después de '--create='
        }
    }

    // Si no se usó la bandera --create, lo extraemos del nombre de la migración de forma nativa
    if (!$tableName) {
        $tableName = str_replace(['create_', '_table'], '', $name);
    }

    // Llamamos a la función pasando el nombre de la migración y la tabla limpia
    generarMigración($name, $tableName);
    exit(0);
}

// ==========================================
// COMANDO: php craft migrate
// ==========================================
if ($command === 'migrate') {
    mysqli_report(MYSQLI_REPORT_OFF);
    $mysqli = new mysqli(DB_HOST, DB_USER, DB_PASS, DB_NAME);

    if ($mysqli->connect_error) {
        die("\e[31mError de conexión a la BD:\e[0m " . $mysqli->connect_error . "\n");
    }
    $mysqli->set_charset('utf8mb4');

    // Modificado: Agregamos la columna 'batch' a la tabla de control
    $mysqli->query("CREATE TABLE IF NOT EXISTS migrations (
        id INT AUTO_INCREMENT PRIMARY KEY,
        migration VARCHAR(255) NOT NULL,
        batch INT NOT NULL,
        executed_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;");

    $executed = [];
    $result = $mysqli->query("SELECT migration FROM migrations");
    if ($result) {
        while ($row = $result->fetch_assoc()) $executed[] = $row['migration'];
    }

    if (!is_dir(MIGRATIONS_PATH)) {
        echo "\e[33mNo se encontró la carpeta de migraciones.\e[0m\n";
        exit(0);
    }

    $files = scandir(MIGRATIONS_PATH);
    $pendingMigrations = [];

    foreach ($files as $file) {
        if (pathinfo($file, PATHINFO_EXTENSION) === 'php' && !in_array($file, $executed)) {
            $pendingMigrations[] = $file;
        }
    }

    if (empty($pendingMigrations)) {
        echo "\e[32mNada que migrar. Tu base de datos está al día.\e[0m\n";
        exit(0);
    }

    // NUEVO: Calcular el número del lote actual (El máximo actual + 1)
    $batchResult = $mysqli->query("SELECT MAX(batch) as max_batch FROM migrations");
    $batchRow = $batchResult->fetch_assoc();
    $currentBatch = ($batchRow['max_batch'] ?? 0) + 1;

    foreach ($pendingMigrations as $file) {
        require_once MIGRATIONS_PATH . $file;
        $pureName = preg_replace('/^[0-9_]+/', '', pathinfo($file, PATHINFO_FILENAME));
        $className = str_replace(' ', '', ucwords(str_replace('_', ' ', $pureName)));

        echo "Migrando: {$file}...\n";

        try {
            if (!class_exists($className)) {
                throw new \Exception("La clase [{$className}] no está definida.");
            }

            $migrationInstance = new $className();
            if (method_exists($migrationInstance, 'connection')) {
                $migrationInstance->connection();
            }
            $migrationInstance->up();

            // Modificado: Guardamos el archivo y le asociamos el lote ($currentBatch)
            $stmt = $mysqli->prepare("INSERT INTO migrations (migration, batch) VALUES (?, ?)");
            $stmt->bind_param('si', $file, $currentBatch);
            $stmt->execute();
            $stmt->close();

            echo "\e[32mMigrado:\e[0m {$file}\n";
        } catch (\Throwable $e) {
            echo "\e[31mError migrando {$file}:\e[0m " . $e->getMessage() . "\n";
            exit(1);
        }
    }
    exit(0);
}

// ==========================================
// COMANDO: php craft migrate:rollback
// ==========================================
if ($command === 'migrate:rollback') {
    mysqli_report(MYSQLI_REPORT_OFF);
    $mysqli = new mysqli(DB_HOST, DB_USER, DB_PASS, DB_NAME);

    if ($mysqli->connect_error) {
        die("\e[31mError de conexión a la BD:\e[0m " . $mysqli->connect_error . "\n");
    }
    $mysqli->set_charset('utf8mb4');

    // Verificar si la tabla existe
    $tableCheck = $mysqli->query("SHOW TABLES LIKE 'migrations'");
    if ($tableCheck->num_rows === 0) {
        echo "\e[32mNo existe una tabla de migraciones. Nada que revertir.\e[0m\n";
        exit(0);
    }

    // Obtener el número del último lote ejecutado
    $batchResult = $mysqli->query("SELECT MAX(batch) as max_batch FROM migrations");
    $batchRow = $batchResult->fetch_assoc();
    $lastBatch = $batchRow['max_batch'] ?? null;

    if (!$lastBatch) {
        echo "\e[32mNada que revertir. No se encontraron migraciones registradas.\e[0m\n";
        exit(0);
    }

    // Seleccionar las migraciones del último lote en orden descendente (las últimas creadas caen primero)
    $stmt = $mysqli->prepare("SELECT id, migration FROM migrations WHERE batch = ? ORDER BY id DESC");
    $stmt->bind_param('i', $lastBatch);
    $stmt->execute();
    $result = $stmt->get_result();

    $rolledBackCount = 0;
    while ($row = $result->fetch_assoc()) {
        $file = $row['migration'];
        $migrationId = $row['id'];
        $filePath = MIGRATIONS_PATH . $file;

        if (!file_exists($filePath)) {
            echo "\e[33mAdvertencia:\e[0m No se encontró el archivo {$file}. Eliminando registro de control.\n";
        } else {
            require_once $filePath;
            $pureName = preg_replace('/^[0-9_]+/', '', pathinfo($file, PATHINFO_FILENAME));
            $className = str_replace(' ', '', ucwords(str_replace('_', ' ', $pureName)));

            echo "Revirtiendo: {$file}...\n";

            try {
                if (!class_exists($className)) {
                    throw new \Exception("La clase [{$className}] no está definida.");
                }

                $migrationInstance = new $className();
                if (method_exists($migrationInstance, 'connection')) {
                    $migrationInstance->connection();
                }
                $migrationInstance->down(); // Ejecuta el borrado/modificación de la tabla
                echo "\e[33mRevertido:\e[0m {$file}\n";
            } catch (\Throwable $e) {
                echo "\e[31mError revirtiendo {$file}:\e[0m " . $e->getMessage() . "\n";
                exit(1);
            }
        }

        // Eliminar el registro de la base de datos
        $deleteStmt = $mysqli->prepare("DELETE FROM migrations WHERE id = ?");
        $deleteStmt->bind_param('i', $migrationId);
        $deleteStmt->execute();
        $deleteStmt->close();
        $rolledBackCount++;
    }
    $stmt->close();

    echo "\e[32mSe revirtió con éxito el lote [{$lastBatch}] ({$rolledBackCount} migraciones).\e[0m\n";
    exit(0);
}

// ==========================================
// COMANDO: php craft make:controller
// ==========================================
if ($command === 'make:controller') {
    if (!$name) {
        echo "\e[31mError:\e[0m Debes especificar el nombre.\n";
        exit(1);
    }
    generarControlador($name, $isResource);
    if ($createModel) {
        $baseName = str_replace('Controller', '', $name);
        generarModelo($baseName);
    }
    exit(0);
}

// ==========================================
// COMANDO COMBINADO: php craft make:model
// ==========================================
if ($command === 'make:model') {
    if (!$name) {
        echo "\e[31mError:\e[0m Debes especificar el nombre del modelo.\n";
        exit(1);
    }

    // 1. Crear el Modelo base siempre
    generarModelo($name);

    // 2. Si tiene la bandera de migración (-m)
    if ($createMigration) {
        generarMigración($name);
    }

    // 3. Si tiene la bandera de controlador (-c o -r)
    if ($createController || $isResource) {
        generarControlador($name . 'Controller', $isResource);
    }

    exit(0);
}

// ==========================================
// FUNCIÓN AUXILIAR DE GENERACIÓN
// ==========================================
function generarSeeder($name, $modelName = null) {
    if (!is_dir(SEEDERS_PATH)) {
        mkdir(SEEDERS_PATH, 0755, true);
    }

    $targetFile = SEEDERS_PATH . $name . '.php';

    if (file_exists($targetFile)) {
        echo "\e[33mEl seeder [{$name}] ya existe.\e[0m\n";
        return;
    }

    if (!file_exists(STUBS_PATH . 'Seeder.stub')) {
        echo "\e[31mError:\e[0m Falta plantilla Seeder.stub en Core/Stubs/\n";
        return;
    }

    $template = file_get_contents(STUBS_PATH . 'Seeder.stub');
    
    // 1. Deducir el nombre de la tabla basándonos en el Modelo (estilo Laravel/tu framework)
    $tableName = 'tu_tabla'; // Valor por defecto si no pasan --model
    
    if ($modelName) {
        // Convertir CamelCase a snake_case (ej: OfertaEducativa -> oferta_educativa)
        $snake = strtolower(preg_replace('/(?<!^)[A-Z]/', '_$0', $modelName));
        
        // Pluralización simple (ej: user -> users, oferta_educativa -> oferta_educativas)
        $tableName = $snake;
        if (!str_ends_with($tableName, 's')) {
            $tableName .= 's';
        }
    }

    // 2. Reemplazar las variables exactas de tu Stub
    $compiled = str_replace(
        ['{{SeederClass}}', '{{TableName}}'], 
        [$name, $tableName], 
        $template
    );

    file_put_contents($targetFile, $compiled);
    echo "\e[32mSeeder creado con éxito:\e[0m database/seeders/{$name}.php (Tabla asociada: {$tableName})\n";
}

// ==========================================
// COMANDO: php craft make:seeder
// ==========================================
if ($command === 'make:seeder') {
    if (!$name) {
        echo "\e[31mError:\e[0m Debes especificar el nombre del seeder.\n";
        exit(1);
    }

    $modelName = null;

    // Analizar las banderas buscando --model=Nombre
    foreach ($flags as $flag) {
        if (str_starts_with($flag, '--model=')) {
            $modelName = substr($flag, 8); // Extrae lo que esté después de '--model='
        }
    }

    generarSeeder($name, $modelName);
    exit(0);
}

// ==========================================
// COMANDO: php craft db:seed {Nombre opcional} [--refresh]
// ==========================================
if ($command === 'db:seed') {
    mysqli_report(MYSQLI_REPORT_OFF);
    $mysqli = new mysqli(DB_HOST, DB_USER, DB_PASS, DB_NAME);

    if ($mysqli->connect_error) {
        die("\e[31mError de conexión a la BD:\e[0m " . $mysqli->connect_error . "\n");
    }
    $mysqli->set_charset('utf8mb4');

    if (!is_dir(SEEDERS_PATH)) {
        echo "\e[33mNo se encontró la carpeta de seeders.\e[0m\n";
        exit(0);
    }

    // Detectar si el usuario envió la bandera de refrescado (--refresh o -r)
    $shouldRefresh = in_array('--refresh', $flags) || in_array('-r', $flags);

    // 🔥 ESCUDO DE SEGURIDAD PARA PRODUCCIÓN
    // Nota: Reemplaza 'ENVIRONMENT' o 'production' por las constantes reales de tu App/config/config.php si difieren.
    $isProduction = (defined('ENVIRONMENT') && ENVIRONMENT === 'production') || (defined('DB_HOST') && DB_HOST !== 'localhost' && DB_HOST !== '127.0.0.1');

    if ($shouldRefresh && $isProduction) {
        echo "\n\e[41m  ¡ADVERTENCIA CRÍTICA DE SEGURIDAD!  \e[0m\n";
        echo "\e[31mEstás intentando ejecutar un --refresh en un entorno de PRODUCCIÓN.\e[0m\n";
        echo "\e[31mEsta acción ELIMINARÁ permanentemente todos los datos de las tablas afectadas.\e[0m\n\n";
        echo "¿Estás completamente seguro de continuar? (Escribe 'si' en mayúscula o minúscula para confirmar): ";
        
        // Abrir la entrada de la terminal para capturar la respuesta del usuario
        $handle = fopen("php://stdin", "r");
        $line = trim(fgets($handle));
        fclose($handle);
        
        if (strtolower($line) !== 'si') {
            echo "\n\e[32mOperación cancelada de manera segura. No se modificó ningún dato.\e[0m\n";
            exit(0);
        }
        echo "\n\e[33mContinuando con el vaciado de tablas bajo tu propia responsabilidad...\e[0m\n\n";
    }

    // Si especificas un seeder concreto (ej: php craft db:seed UserSeeder)
    if ($name && !str_starts_with($name, '-')) {
        if (!str_ends_with($name, 'Seeder')) {
            $name .= 'Seeder';
        }
        $files = [$name . '.php'];
    } else {
        // Si no especificas nombre o pasas la bandera directamente, ejecuta todos
        $files = array_filter(scandir(SEEDERS_PATH), function($file) {
            return pathinfo($file, PATHINFO_EXTENSION) === 'php';
        });
    }

    if (empty($files) || !file_exists(SEEDERS_PATH . reset($files))) {
        echo "\e[33mNo se encontraron archivos de seeders para ejecutar.\e[0m\n";
        exit(0);
    }

    foreach ($files as $file) {
        $filePath = SEEDERS_PATH . $file;
        if (!file_exists($filePath)) {
            echo "\e[31mArchivo no encontrado:\e[0m {$file}\n";
            continue;
        }

        require_once $filePath;
        $className = pathinfo($file, PATHINFO_FILENAME);

        // EXTRAER NOMBRE DE TABLA AUTOMÁTICO: Convierte "UserSeeder" a "users"
        $baseTableName = strtolower(str_replace('Seeder', '', $className)) . 's';

        // Si se solicita refrescar, vaciamos la tabla antes del Seed
        if ($shouldRefresh) {
            echo "\e[33mLimpiando tabla [{$baseTableName}]...\e[0m\n";
            $mysqli->query("SET FOREIGN_KEY_CHECKS = 0;"); // Desactiva restricciones temporalmente
            $mysqli->query("TRUNCATE TABLE {$baseTableName}");
            $mysqli->query("SET FOREIGN_KEY_CHECKS = 1;"); // Reactiva restricciones
        }

        echo "Ejecutando Seeder: {$className}...\n";

        try {
            if (!class_exists($className)) {
                throw new \Exception("La clase [{$className}] no está definida en el archivo.");
            }

            $seederInstance = new $className();
            $seederInstance->run($mysqli);

            echo "\e[32mSeeded:\e[0m {$file}\n";
        } catch (\Exception $e) {
            echo "\e[31mError ejecutando el seeder {$file}:\e[0m " . $e->getMessage() . "\n";
            exit(1);
        }
    }
    exit(0);
}

function generarVistasCrud($name) {
    $tabla = strtolower($name);
    
    // Configurar plurales y singulares descriptivos para las etiquetas
    $pluralCap = ucfirst($tabla);
    $singularCap = ucfirst(str_ends_with($tabla, 's') ? substr($tabla, 0, -1) : $tabla);
    
    // Carpeta destino de vistas según tu estructura
    $vistasDir = __DIR__ . "/resources/views/admin/{$tabla}";
    if (!is_dir($vistasDir)) {
        mkdir($vistasDir, 0755, true);
    }

    // Conexión nativa MySQL para inspeccionar la tabla
