function inyectarRutasCrud($name) {
    $tabla = strtolower($name);
    
    // ALGORITMO DE SINGULARIZACIÓN COMPUESTA CORREGIDO:
    $palabras = explode('_', $tabla);
    $palabrasSingulares = array_map(function($palabra) {
        if (str_ends_with($palabra, 's')) {
            return substr($palabra, 0, -1);
        }
        return $palabra;
    }, $palabras);

    $modelName = implode('', array_map('ucfirst', $palabrasSingulares));
    $controllerName = $modelName . 'Controller';
    
    $routesFile = __DIR__ . '/routes/web.php';
    if (!file_exists($routesFile)) return;

    $contenidoRutas = file_get_contents($routesFile);

    if (empty($contenidoRutas)) {
        echo "\e[31mError: El archivo de rutas está vacío.\e[0m\n";
        return;
    }

    if (strpos($contenidoRutas, "'/{$tabla}'") !== false || strpos($contenidoRutas, "/{$tabla}/") !== false) {
        echo "\e[33mLas rutas para [/{$tabla}] ya existen.\e[0m\n";
        return;
    }

    // Estructura RESTful con namespaces en línea (Evita romper la cabecera)
    $bloqueRutas = "\n/** Rutas para " . ucfirst($tabla) . " */\n";
    $bloqueRutas .= "Route::get('/{$tabla}', [\App\Controllers\\{$controllerName}::class, 'index'], [\$authMiddleware]);\n";
    $bloqueRutas .= "Route::get('/{$tabla}/create', [\App\Controllers\\{$controllerName}::class, 'create'], [\$authMiddleware]);\n";
    $bloqueRutas .= "Route::post('/{$tabla}', [\App\Controllers\\{$controllerName}::class, 'store'], [\$authMiddleware]);\n";
    $bloqueRutas .= "Route::get('/{$tabla}/wastebasket', [\App\Controllers\\{$controllerName}::class, 'wastebasket'], [\$authMiddleware]);\n";
    $bloqueRutas .= "Route::post('/{$tabla}/:id/restore', [\App\Controllers\\{$controllerName}::class, 'restore'], [\$authMiddleware]);\n";
    $bloqueRutas .= "Route::post('/{$tabla}/:id/destroy', [\App\Controllers\\{$controllerName}::class, 'destroy'], [\$authMiddleware]);\n";
    $bloqueRutas .= "Route::post('/{$tabla}/:id/delete', [\App\Controllers\\{$controllerName}::class, 'delete'], [\$authMiddleware]);\n";
    $bloqueRutas .= "Route::get('/{$tabla}/:id/edit', [\App\Controllers\\{$controllerName}::class, 'edit'], [\$authMiddleware]);\n";
    $bloqueRutas .= "Route::post('/{$tabla}/:id/update', [\App\Controllers\\{$controllerName}::class, 'update'], [\$authMiddleware]);\n";

    if (strpos($contenidoRutas, 'Route::dispatch();') !== false) {
        $nuevoContenido = str_replace('Route::dispatch();', $bloqueRutas . "\nRoute::dispatch();", $contenidoRutas);
    } else {
        $nuevoContenido = $contenidoRutas . $bloqueRutas;
    }

    if (!empty($nuevoContenido) && strlen($nuevoContenido) > strlen($contenidoRutas)) {
        file_put_contents($routesFile, $nuevoContenido);
        echo "\e[32mRutas inyectadas con total seguridad en:\e[0m App/config/routes.php\n";
    }
}

